{
    "name": "scalyn/qa-assistant",
    "description": "Website QA, SEO validation, and launch readiness tool for WordPress.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.2"
    },
    "autoload": {
        "psr-4": {
            "Scalyn\\QA\\": "includes/"
        },
        "classmap": [
            "includes/"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
